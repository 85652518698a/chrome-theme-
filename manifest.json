{
  "manifest_version": 3,
  "name": "Brutalist Chrome",
  "short_name": "Brutalist",
  "version": "1.0.0",
  "version_name": "1.0.0",
  "description": "A brutalist dark monochrome theme with warm undertones — new tab dashboard, side panel, and productivity tools.",
  "homepage_url": "https://github.com/85652518698a/chrome-theme-",
  "author": "Brutalist Chrome",
  "minimum_chrome_version": "116",

  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "64": "assets/icons/icon64.png",
    "128": "assets/icons/icon128.png"
  },

  "permissions": [
    "storage",
    "identity",
    "geolocation",
    "alarms",
    "tabs",
    "bookmarks",
    "topSites",
    "management",
    "notifications",
    "contextMenus",
    "sidePanel"
  ],

  "host_permissions": [
    "https://www.google.com/*",
    "https://api.openweathermap.org/*",
    "https://api.quotable.io/*",
    "https://api.unsplash.com/*",
    "https://www.googleapis.com/*"
  ],

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open Brutalist Chrome popup"
    },
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Toggle side panel"
    },
    "toggle-theme": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Toggle theme"
    },
    "open-command-palette": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open command palette"
    },
    "search-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Search selected text"
    },
    "quick-add-todo": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Quick add todo"
    }
  },

  "chrome_url_overrides": {
    "newtab": "newtab/index.html"
  },

  "side_panel": {
    "default_path": "extension/sidebar/sidebar.html"
  },

  "options_ui": {
    "page": "extension/options/options.html",
    "open_in_tab": true
  },

  "action": {
    "default_popup": "extension/popup/popup.html",
    "default_title": "Brutalist Chrome",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "64": "assets/icons/icon64.png",
      "128": "assets/icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "extension/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["extension/content.js"],
      "run_at": "document_start"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "assets/*",
        "theme/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "theme": {
    "images": {
      "theme_frame": "assets/wallpapers/background.webp",
      "theme_toolbar": "assets/wallpapers/background.webp",
      "theme_tab_background": "assets/wallpapers/background.webp",
      "theme_ntp_background": "assets/wallpapers/background.webp"
    },
    "colors": {
      "frame": [26, 26, 26],
      "frame_inactive": [17, 17, 17],
      "frame_incognito": [17, 17, 17],
      "frame_incognito_inactive": [10, 10, 10],
      "toolbar": [42, 42, 42],
      "toolbar_button_icon": [192, 192, 192],
      "toolbar_text": [240, 236, 228],
      "tab_background_color": [34, 34, 34],
      "tab_background_text": [160, 152, 136],
      "tab_foreground_color": [240, 236, 228],
      "tab_text": [240, 236, 228],
      "bookmark_text": [240, 236, 228],
      "ntp_background": [17, 17, 17],
      "ntp_text": [240, 236, 228],
      "ntp_link": [196, 168, 130],
      "ntp_snippet": [160, 152, 136],
      "ntp_header": [240, 236, 228],
      "button_background": [51, 51, 51],
      "control_background": [34, 34, 34],
      "control_border": [51, 51, 51],
      "omnibox_background": [34, 34, 34],
      "omnibox_text": [240, 236, 228],
      "omnibox_dropdown_background": [26, 26, 26],
      "omnibox_dropdown_text": [240, 236, 228],
      "omnibox_dropdown_selection": [51, 51, 51]
    },
    "tints": {
      "buttons": [0.1, 0.5, 0.5],
      "frame": [-1, -1, -1],
      "background_tab": [0.08, 0.32, 0.48]
    },
    "properties": {
      "ntp_background_alignment": "center",
      "ntp_background_repeat": "no-repeat",
      "ntp_logo_alternate": 1
    }
  }
}
