<svg xmlns="http://www.w3.org/2000/svg" width="1280" height="800" viewBox="0 0 1280 800">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#111111"/>
      <stop offset="100%" style="stop-color:#1a1a1a"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#c4a882"/>
      <stop offset="100%" style="stop-color:#d4c4a8"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1280" height="800" fill="url(#bg)"/>

  <!-- Chrome Window Frame -->
  <rect x="40" y="40" width="1200" height="720" rx="8" fill="#2a2a2a" stroke="#333333" stroke-width="1"/>
  <!-- Title bar -->
  <rect x="40" y="40" width="1200" height="40" rx="8" fill="#1a1a1a"/>
  <rect x="40" y="72" width="1200" height="8" fill="#1a1a1a"/>
  <!-- Window controls -->
  <circle cx="68" cy="60" r="6" fill="#555"/>
  <circle cx="88" cy="60" r="6" fill="#555"/>
  <circle cx="108" cy="60" r="6" fill="#555"/>
  <!-- URL bar -->
  <rect x="260" y="50" width="480" height="20" rx="10" fill="#222222" stroke="#333333" stroke-width="1"/>
  <text x="500" y="64" font-family="monospace" font-size="11" fill="#a09888" text-anchor="middle">github.com/brutalist-chrome</text>

  <!-- Toolbar -->
  <rect x="40" y="80" width="1200" height="32" fill="#222222"/>

  <!-- New Tab Content -->
  <!-- Weather Widget -->
  <rect x="100" y="140" width="280" height="160" rx="6" fill="#222222" stroke="#333333" stroke-width="1"/>
  <text x="130" y="170" font-family="sans-serif" font-size="14" font-weight="bold" fill="#f0ece4">🌤️ London</text>
  <text x="130" y="200" font-family="sans-serif" font-size="36" font-weight="bold" fill="#c4a882">18°C</text>
  <text x="130" y="225" font-family="sans-serif" font-size="13" fill="#a09888">Partly Cloudy</text>
  <text x="130" y="250" font-family="sans-serif" font-size="12" fill="#555555">Humidity: 65%  Wind: 12 km/h</text>

  <!-- Clock Widget -->
  <rect x="420" y="140" width="480" height="160" rx="6" fill="#222222" stroke="#333333" stroke-width="1"/>
  <text x="660" y="200" font-family="sans-serif" font-size="56" font-weight="bold" fill="#f0ece4" text-anchor="middle">14:32</text>
  <text x="660" y="230" font-family="sans-serif" font-size="14" fill="#a09888" text-anchor="middle">Friday, June 26, 2026</text>
  <text x="660" y="255" font-family="sans-serif" font-size="12" fill="#555555" text-anchor="middle">Good afternoon, Alex</text>

  <!-- Quick Links -->
  <rect x="940" y="140" width="280" height="160" rx="6" fill="#222222" stroke="#333333" stroke-width="1"/>
  <text x="970" y="170" font-family="sans-serif" font-size="13" font-weight="bold" fill="#f0ece4">⚡ Quick Links</text>
  <text x="970" y="198" font-family="sans-serif" font-size="12" fill="#a09888">▸ GitHub</text>
  <text x="970" y="218" font-family="sans-serif" font-size="12" fill="#a09888">▸ Stack Overflow</text>
  <text x="970" y="238" font-family="sans-serif" font-size="12" fill="#a09888">▸ DevDocs</text>
  <text x="970" y="258" font-family="sans-serif" font-size="12" fill="#a09888">▸ Figma</text>
  <text x="970" y="278" font-family="sans-serif" font-size="12" fill="#a09888">▸ Notion</text>

  <!-- Todo Widget -->
  <rect x="100" y="330" width="540" height="180" rx="6" fill="#222222" stroke="#333333" stroke-width="1"/>
  <text x="130" y="360" font-family="sans-serif" font-size="14" font-weight="bold" fill="#f0ece4">✅ Today's Tasks</text>
  <text x="130" y="390" font-family="sans-serif" font-size="13" fill="#f0ece4">◻ Review Q3 roadmap</text>
  <text x="130" y="412" font-family="sans-serif" font-size="13" fill="#f0ece4">◻ Update dependencies</text>
  <text x="130" y="434" font-family="sans-serif" font-size="13" fill="#a09888">◻ Schedule team sync  <tspan fill="#c4a882">✔</tspan></text>
  <text x="130" y="456" font-family="sans-serif" font-size="13" fill="#a09888">◻ Write documentation <tspan fill="#c4a882">✔</tspan></text>
  <text x="130" y="478" font-family="sans-serif" font-size="12" fill="#555555">+ Add new task...  (Ctrl+Shift+Q)</text>

  <!-- Notes Widget -->
  <rect x="680" y="330" width="540" height="180" rx="6" fill="#222222" stroke="#333333" stroke-width="1"/>
  <text x="710" y="360" font-family="sans-serif" font-size="14" font-weight="bold" fill="#f0ece4">📝 Quick Notes</text>
  <rect x="710" y="375" width="200" height="120" rx="4" fill="#2a2a2a" stroke="#333333" stroke-width="1"/>
  <text x="725" y="395" font-family="sans-serif" font-size="11" font-weight="bold" fill="#c4a882">Ideas</text>
  <text x="725" y="415" font-family="sans-serif" font-size="11" fill="#a09888">- Brutalist palette works</text>
  <text x="725" y="433" font-family="sans-serif" font-size="11" fill="#a09888">  well with amber accents</text>
  <text x="725" y="451" font-family="sans-serif" font-size="11" fill="#a09888">- Try monochrome icons</text>
  <text x="725" y="469" font-family="sans-serif" font-size="11" fill="#a09888">- Add more shortcuts</text>
  <rect x="940" y="375" width="200" height="120" rx="4" fill="#2a2a2a" stroke="#333333" stroke-width="1"/>
  <text x="955" y="395" font-family="sans-serif" font-size="11" font-weight="bold" fill="#c4a882">Bugs</text>
  <text x="955" y="415" font-family="sans-serif" font-size="11" fill="#a09888">- Sidebar flash on load</text>
  <text x="955" y="433" font-family="sans-serif" font-size="11" fill="#a09888">- History pagination</text>
  <text x="955" y="451" font-family="sans-serif" font-size="11" fill="#a09888">- Weather cache timeout</text>

  <!-- Footer accent line -->
  <rect x="100" y="570" width="1120" height="1" fill="#333333"/>
  <text x="660" y="600" font-family="sans-serif" font-size="11" fill="#555555" text-anchor="middle">Brutalist Chrome v2.0.0  •  All data stored locally  •  No tracking</text>

  <!-- Accent stripe -->
  <rect x="40" y="752" width="1200" height="8" rx="0" fill="url(#accent)" opacity="0.3"/>
</svg>
