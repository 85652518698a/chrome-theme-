{
  "manifest_version": 3,
  "name": "Brutalist Chrome",
  "version": "1.0.0",
  "description": "A brutalist dark theme enhancement for Chrome with productivity tools",
  "permissions": [
    "storage",
    "tabs",
    "bookmarks",
    "history",
    "notifications",
    "alarms",
    "contextMenus",
    "commands",
    "sidePanel",
    "scripting",
    "activeTab",
    "sessions",
    "favicon"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Brutalist Chrome",
    "default_icon": {
      "16": "../assets/icons/icon16.png",
      "48": "../assets/icons/icon48.png",
      "128": "../assets/icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "options_page": "options/options.html",
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open Brutalist Chrome popup"
    },
    "toggle-sidebar": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Toggle sidebar"
    },
    "toggle-theme": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Toggle theme"
    },
    "open-command-palette": {
      "suggested_key": {
        "default": "Ctrl+Shift+P",
        "mac": "Command+Shift+P"
      },
      "description": "Open command palette"
    },
    "search-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Search selected text"
    },
    "quick-add-todo": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Quick add todo"
    }
  },
  "icons": {
    "16": "../assets/icons/icon16.png",
    "48": "../assets/icons/icon48.png",
    "128": "../assets/icons/icon128.png"
  }
}
